# ─────────────────────────────────────────────────────────────
# Azure OpenAI (required)
# ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2

# ─────────────────────────────────────────────────────────────
# CORS / Frontend (set after deploying frontend on Vercel)
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:8000"]
FRONTEND_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────
# Azure Container Apps deployment config
# ─────────────────────────────────────────────────────────────
# AZURE_RESOURCE_GROUP=web-crawler-rg
# AZURE_LOCATION=eastus
# AZURE_ACR_NAME=webcrawleracr
# AZURE_CONTAINER_APP_NAME=web-crawler-api
# AZURE_CONTAINER_ENV_NAME=web-crawler-env
