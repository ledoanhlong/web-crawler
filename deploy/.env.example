# ─────────────────────────────────────────────────────────────
# Azure OpenAI (required)
# ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2

# ─────────────────────────────────────────────────────────────
# Azure OpenAI — Vision model (GPT-4o for screenshot-based planning)
# Deploy GPT-4o from Azure AI Foundry Model Catalog
# ─────────────────────────────────────────────────────────────
AZURE_VISION_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_VISION_API_KEY=your-api-key-here
AZURE_VISION_DEPLOYMENT=gpt-4o
USE_VISION_PLANNING=true

# ─────────────────────────────────────────────────────────────
# Azure AI Foundry — Claude Opus 4.6 (complex site extraction)
# Deploy from Azure AI Foundry → Model Catalog → Anthropic → Claude
# This creates a serverless "Models as a Service" deployment with its own endpoint
# ─────────────────────────────────────────────────────────────
AZURE_CLAUDE_ENDPOINT=https://your-claude-deployment.services.ai.azure.com/
AZURE_CLAUDE_API_KEY=your-claude-api-key-here
AZURE_CLAUDE_DEPLOYMENT=claude-opus-4-6
USE_CLAUDE_EXTRACTION=true

# ─────────────────────────────────────────────────────────────
# CORS / Frontend (set after deploying frontend on Vercel)
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:8000"]
FRONTEND_URL=https://your-app.vercel.app
